# Server (never commit real keys)
BIRDEYE_API_KEY=

# Optional: solana (default), ethereum, base, etc.
# BIRDEYE_CHAIN=solana

# Cache window for bundled radar responses (ms). Default 900000 (15 min).
# RADAR_CACHE_MS=900000

# Tokens to enrich per scan (each needs security + overview). Default 10.
# RADAR_TOKEN_LIMIT=10

# Minimum gap between Birdeye HTTP calls (ms). Default 450.
# BIRDEYE_MIN_INTERVAL_MS=450

# Retries after HTTP 429. Default 6.
# BIRDEYE_MAX_RETRIES=6

# API port for local Express
# PORT=8787

# Restrict CORS in production, e.g. https://your-app.vercel.app
# CORS_ORIGIN=https://your-app.vercel.app
